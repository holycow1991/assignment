{
  "name": "@assignment/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "test": "pnpm test:endpoints",
    "test:endpoints": "dotenv -e .env.test -- jest --config ./jest.config.ts --runInBand",
    "test:db:migrate": "dotenv -e .env.test -- pnpm migration:run:dev",
    "typeorm": "typeorm-ts-node-commonjs -d src/database/data-source.ts",
    "migration:run:dev": "pnpm typeorm migration:run",
    "migration:revert:dev": "pnpm typeorm migration:revert",
    "migration:show": "pnpm typeorm migration:show",
    "migration:run": "typeorm -d dist/database/data-source.js migration:run",
    "migration:revert": "typeorm -d dist/database/data-source.js migration:revert",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@assignment/types": "workspace:*",
    "@nestjs/common": "^11.1.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.1",
    "@nestjs/platform-express": "^11.1.1",
    "@nestjs/typeorm": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "pg": "^8.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.22"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.19",
    "@types/express": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.3",
    "@types/supertest": "^7.2.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  }
}
